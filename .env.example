# Database (Development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_task_orchestrator?schema=public"

# Database (Test) - Used by e2e tests
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_task_orchestrator_test?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600
# Leave REDIS_PASSWORD empty for local Docker Redis.
# For Upstash / managed Redis: set password and REDIS_TLS=true
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
PORT=3000
NODE_ENV=development
