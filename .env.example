# =============================================================================
# AI Task Orchestrator - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# NEVER commit real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Development)
# -----------------------------------------------------------------------------
# Local Postgres from docker-compose.
# In production (Render), set DATABASE_URL to the Neon pooled connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_task_orchestrator?schema=public"

# -----------------------------------------------------------------------------
# Database (Test) - Used by e2e tests
# -----------------------------------------------------------------------------
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_task_orchestrator_test?schema=public"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Local (Docker): leave REDIS_PASSWORD empty and REDIS_TLS=false.
# Production (Upstash): set host, password, and REDIS_TLS=true.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600
REDIS_PASSWORD=
REDIS_TLS=false

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# In production, generate a strong secret (e.g. `openssl rand -base64 48`).
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
